{
  "$schema": "https://opencode.ai/config.json",
  "server": {
    "port": 9631,
    "hostname": "0.0.0.0"
  },
  "mcp": {
    "google-sheets": {
      "enabled": true,
      "type": "local",
      "command": ["uvx","mcp-google-sheets@latest"],
      "environment": {
        "CREDENTIALS_CONFIG": "{env:CREDENTIALS_CONFIG}",
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "bitrix24-dev-docs": {
      "type": "remote",
      "url": "https://mcp-dev.bitrix24.tech/mcp",
    },    
    "openclaw": {
      "type": "local",
      "command": ["npx","-y", "openclaw-mcp"],
      "environment": {
        "OPENCLAW_URL": "http://127.0.0.1:18789",
        "OPENCLAW_GATEWAY_TOKEN": "{env:OPENCLAW_TOKEN}",
        "OPENCLAW_MODEL": "openclaw",
        "OPENCLAW_TIMEOUT_MS": "300000"
      }
    },
    "mattermost": {
      "type": "local",
      "command": ["node", "/home/{env:DEV_CONTAINER_NAME}/.mattermost-mcp/build/index.js"],
      "environment": {
        "MATTERMOST_URL": "{env:MATTERMOST_URL}",
        "MATTERMOST_ACCESS_TOKEN": "{env:MATTERMOST_ACCESS_TOKEN}",
        "MATTERMOST_TOKEN_ID": "{env:MATTERMOST_TOKEN_ID}",
        "MATTERMOST_TEAM_ID": "{env:MATTERMOST_TEAM_ID}"
      }
    },
    "mcp-graylog": {
      "type": "local",
      "command": ["sh", "-c", "cd /home/{env:DEV_CONTAINER_NAME}/.mcp_graylog && ./start.sh"],
      "environment": {
        "GRAYLOG_ENDPOINT": "{env:GRAYLOG_ENDPOINT}",
        "GRAYLOG_USERNAME": "{env:GRAYLOG_USERNAME}",
        "GRAYLOG_PASSWORD": "{env:GRAYLOG_PASSWORD}",
        "GRAYLOG_VERIFY_SSL": "{env:GRAYLOG_VERIFY_SSL}"
      }
    },
    "atlassian": {
      "type": "local",
      "command": ["uvx","mcp-atlassian"],
      "environment": {
        "JIRA_URL": "https://jira.agrohistory.com",
        "JIRA_PERSONAL_TOKEN": "{env:JIRA_PERSONAL_TOKEN}",
        "CONFLUENCE_URL": "https://confluence.agrohistory.com",
        "CONFLUENCE_PERSONAL_TOKEN": "{env:CONFLUENCE_PERSONAL_TOKEN}"
      }
    },
    "docling": {
      "type": "remote",
      "url": "http://docling-serve:5002/mcp",
      "timeout": 300000
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp", "--browser-url=http://127.0.0.1:9222"]
    },
    "n8n-mcp": {
      "type": "local",
      "command": ["npx", "-y", "n8n-mcp"],
      "timeout": 300000,
      "environment": {
        "N8N_API_URL": "{env:N8N_API_URL}",
        "N8N_API_KEY": "{env:N8N_API_KEY}"
      }
    },
    "mcp-pandoc": {
      "type": "local",
      "command": ["uvx","mcp-pandoc"]
    },
    "bitrix24-mcp": {
      "type": "local",
      "command": ["uvx","bitrix24-mcp"]
    },
    "gitlab-mcp": {
      "type": "local",
      "command": ["npx","-y","@zereight/mcp-gitlab"],
      "environment": {
        "GITLAB_PERSONAL_ACCESS_TOKEN": "{env:GITLAB_PERSONAL_ACCESS_TOKEN}",
        "GITLAB_API_URL": "https://gitlab.agroassist.ru/api/v4",
        "GITLAB_READ_ONLY_MODE": "true",
      }
    },
    "org-mcp": {
      "type": "local",
      "command": ["sh", "-c", "/home/work/.emacs.d/emacs-mcp-stdio.sh --server-id=org-mcp --socket=/tmp/emacs1000/server --init-function=org-mcp-enable --stop-function=org-mcp-disable"],
      "environment": {
        "HOME": "/home/work",
        "EMACSLOADPATH": "/home/work/.emacs.d/elpa"
      }
    }
  },
  "provider": {
    "vsegpt": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "VseGpt",
      "options": {
        "baseURL": "https://api.vsegpt.ru/v1",
        "apiKey": "{env:VSEGPT_API_KEY}"
      },
      "models":{
        "deepseek/deepseek-chat": {
          "name" : "DeepSeek",
        },
        "deepseek/deepseek-v4-pro": {
          "name" : "DeepSeek-v4-Pro",
        },
        "deepseek/deepseek-v4-pro-thinking": {
          "name" : "DeepSeek-v4-Pro-Thinking",
        },
        "openai/gpt-5.4-nano": {
          "name" : "GPT-5.4-nano",          
        },
        "google/gemini-3-flash-pre": {
          "name" : "Gemini-3-flash-pre",          
        },
        "x-ai/grok-4.1-fast": {
          "name" : "Grok-4.1-fast",          
        },
        "qwen/qwen3-coder-next": {
          "name" : "Qwen3-Coder-Next",          
        },
        "anthropic/claude-sonnet-4.6": {
          "name" : "Claude-Sonnet-4.6",          
        }
      }
    }
  },
  "watcher": {
    "ignore": ["deploy/**", ".devcontainer/**", ".archive/**"]
  }
}
